	cd /home/island/EDEN/catkin_ws/build && $(MAKE) $(MAKESILENT) -f Mapping_mr_dtg_plus/CMakeFiles/spectral_v2_policy_test.dir/build.make Mapping_mr_dtg_plus/CMakeFiles/spectral_v2_policy_test.dir/test/spectral_v2_policy_test.cpp.i
.PHONY : test/spectral_v2_policy_test.cpp.i

test/spectral_v2_policy_test.s: test/spectral_v2_policy_test.cpp.s
.PHONY : test/spectral_v2_policy_test.s

